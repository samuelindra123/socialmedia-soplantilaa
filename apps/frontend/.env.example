# Public URLs used in browser (socket, media fallback, links)
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ASSET_BASE_URL="http://localhost:4000"

# Server-only URL used by Next.js Server Actions / Route Handlers
BACKEND_API_URL="http://localhost:4000"

# Must be identical to backend NEXT_SERVER_ACTION_API_TOKEN
NEXT_SERVER_ACTION_API_TOKEN="change-this-with-a-long-random-internal-token"

# E2E default base URL
BASE_URL="http://127.0.0.1:3000"
