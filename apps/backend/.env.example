NODE_ENV="development"
PORT="4000"

# Database (Prisma - legacy)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/renunganku"
DATABASE_URL_POOLING="postgresql://postgres:postgres@localhost:6543/renunganku"

# Supabase (untuk video metadata)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="your-service-role-key"

# Optional Redis (if empty, app uses localhost fallback)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-this-with-a-long-random-secret"
JWT_EXPIRATION="7d"

# App URLs
API_URL="http://localhost:4000"
FRONTEND_URL="http://localhost:3000"

# Shared secret token for Next.js server layer -> backend API calls
NEXT_SERVER_ACTION_API_TOKEN="change-this-with-a-long-random-internal-token"

# Email provider
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
RESEND_FROM_NAME="Renunganku"
RESEND_FROM_EMAIL="noreply@your-resend-domain.com"
MAIL_SUPPORT_EMAIL="support@your-domain.com"
MAIL_WEBSITE_URL="https://your-frontend-domain.com"
MAIL_PRIVACY_URL="https://your-frontend-domain.com/privacy"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_OAUTH_REDIRECT="http://localhost:4000/auth/google/callback"
GOOGLE_OAUTH_STATE_SECRET="change-this-with-a-long-random-google-oauth-state-secret"

# Appwrite Cloud Storage
APPWRITE_ENDPOINT="https://sgp.cloud.appwrite.io/v1"
APPWRITE_PROJECT_ID="your-appwrite-project-id"
APPWRITE_API_KEY="your-appwrite-api-key"
APPWRITE_BUCKET_ID="your-appwrite-bucket-id"

# Email System (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=noreply@soplantila.com

# Frontend URL for email links
FRONTEND_URL=http://localhost:3000
